# Django
SECRET_KEY=django-insecure-your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,https://yourdomain.com

# Database (leave empty to use SQLite for development)
# Render will provide DATABASE_URL automatically
DATABASE_URL=

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/accounts/google/callback/

# Email (SMTP - use Gmail for dev, SendGrid for production)
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
# For production, use SendGrid instead (no IP blocks):
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=your-sendgrid-api-key
# DEFAULT_FROM_EMAIL=your-verified-sender@example.com

# Cloudinary (for production media storage)
CLOUDINARY_URL=cloudinary://your-api-key:your-api-secret@your-cloud-name

# Together AI
TOGETHER_API_KEY=your-together-api-key
